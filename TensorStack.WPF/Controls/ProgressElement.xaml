<UserControl x:Class="TensorStack.WPF.Controls.ProgressElement"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             Name="ProgressElementUI">
    <Grid DataContext="{Binding ElementName=ProgressElementUI}" >
        <ProgressBar x:Name="ProgressBarControl" Maximum="{Binding Progress.Maximum}" Value="{Binding Progress.Value}" HorizontalAlignment="Center" Foreground="{Binding Foreground}" Background="{Binding Background}">
            <ProgressBar.Style>
                <Style TargetType="{x:Type ProgressBar}" BasedOn="{StaticResource {x:Type ProgressBar}}">
                    <Setter Property="IsIndeterminate" Value="False"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Progress.Maximum, ElementName=ProgressElementUI}" Value="-1">
                            <Setter Property="IsIndeterminate" Value="True"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>
        <TextBlock Text="{Binding Progress.Message}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="#BFFFFFFF">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="1" Opacity="1" />
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</UserControl>
