<controls:BaseControl x:Class="TensorStack.WPF.Controls.AddOnButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:TensorStack.WPF.Controls"
             mc:Ignorable="d" 
             d:DesignWidth="200" 
             x:Name="AddOnButtonControl" HorizontalContentAlignment="Stretch">
    <Grid DataContext="{Binding ElementName=AddOnButtonControl}" >
        <Button Command="{Binding Command}" CommandParameter="{Binding CommandParameter}" HorizontalContentAlignment="Stretch" Background="{StaticResource ComboBoxBackground}" BorderBrush="{StaticResource ComboBoxBorder}">
            <controls:FontAwesome Icon="{Binding Icon}" IconStyle="{Binding IconStyle}" Color="{Binding IconColor}" Size="{Binding IconSize}" Margin="{Binding IconMargin}" Opacity="{Binding IconOpacity}"/>
        </Button>
    </Grid>
</controls:BaseControl>
